# ============================================================
#  .env.example — TEMPLATE AN TOÀN (commit lên GitHub được)
#  Sao chép thành .env rồi điền giá trị THẬT vào
#  File .env KHÔNG ĐƯỢC commit lên GitHub (đã có trong .gitignore)
# ============================================================

# ── ADMIN ──────────────────────────────────────────────────
ADMIN_USER=admindchua
ADMIN_PASS=doi_mat_khau_ngay_truoc_khi_deploy

# ── MÃ HÓA DỮ LIỆU CÁ NHÂN (AES-256-GCM) ──────────────────
# Tạo key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Dán 64 ký tự hex vào đây — KHÔNG ĐƯỢC MẤT KEY này sau khi đã có dữ liệu!
ENCRYPTION_KEY=your_64_char_hex_key_here_generate_with_node_command_above

# ── EMAIL ADMIN (dùng Gmail App Password để lấy lại pass) ──
ADMIN_EMAIL=youremail@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# ── EMAIL TỰ ĐỘNG KHÁCH HÀNG (Resend) ──────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── WEBSITE URL ────────────────────────────────────────────
SITE_URL=https://your-domain.com.vn

# ── PORT (Railway tự set, không cần điền) ──────────────────
# PORT=3000
